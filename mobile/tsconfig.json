{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./*"
      ]
    },
    "strict": false,
    "rootDir": ".",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "preserveSymlinks": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "noImplicitAny": false,
    "types": [
      "node",
      "react",
      "vite/client"
    ],
    "lib": [
      "dom",
      "esnext"
    ]
  },
  "exclude": [
    "node_modules",
    ".expo",
    "**/dist",
    "**/types",
    "**/__tests__",
    "ios",
    "android"
  ],
  "extends": "expo/tsconfig.base"
}
