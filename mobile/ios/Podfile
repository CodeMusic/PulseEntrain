# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# react-native-permissions: compile in the iOS permission handlers the app uses.
# Without this, check()/request() throw "No permission handler detected".
require_relative '../node_modules/react-native-permissions/scripts/setup'
setup_permissions(['Bluetooth'])

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'PulseEntrain' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'PulseEntrainTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Workaround: Xcode 26 / Apple Clang regressed C++20 consteval, breaking the
    # {fmt} library bundled with React Native. fmt's base.h only disables consteval
    # for OLD Apple Clang (< 14000029L); patch it to disable for ALL Apple Clang.
    # Remove once RN ships a newer fmt that builds clean on Xcode 26.
    fmt_base = File.join(installer.sandbox.root.to_s, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      original = File.read(fmt_base)
      patched = original.gsub(
        '#elif defined(__apple_build_version__) && __apple_build_version__ < 14000029L',
        '#elif defined(__apple_build_version__)  // patched: consteval broken on Xcode 26 clang'
      )
      unless patched == original
        File.chmod(0644, fmt_base)        # CocoaPods leaves fmt sources read-only
        File.write(fmt_base, patched)
      end
    end
  end
end
